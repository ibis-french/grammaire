<button onclick="downloadCSV()">Télécharger tout le rapport</button>

  <script>
function downloadCSV() {
  const studentName = document.getElementById("studentName").value || "Étudiant";

  // Prepare CSV header
  const data = [
    ["Nom de l'étudiant", studentName],
    [],
    ["Exercice: Subjonctif ou Indicatif"]
  ];

  // Exercise 1: Subjonctif ou Indicatif
  const answersSI = {
    si1:"S", si2:"I", si3:"S", si4:"I", si5:"S",
    si6:"I", si7:"S", si8:"S", si9:"I", si10:"S"
  };

  let scoreSI = 0;
  data.push(["Question", "Réponse de l'étudiant", "Réponse correcte"]);

  for (let key in answersSI) {
    let user = document.getElementById(key).value || "";
    let correct = answersSI[key];
    if(user === correct) scoreSI++;
    data.push([key, user, correct]);
  }
  data.push(["Score", scoreSI + " / " + Object.keys(answersSI).length]);
  data.push([]); // Empty line before next exercise

  // Exercise 2: Complétez avec le subjonctif
  data.push(["Exercice: Complétez avec le subjonctif"]);

  const answersSubj = {
    sub1:"fassiez", sub2:"viennent", sub3:"ait", sub4:"saches",
    sub5:"puisse", sub6:"soit", sub7:"veuillent", sub8:"alliez",
    sub9:"prenne", sub10:"servions", sub11:"ayez",
    sub12:"soit", sub13:"fassent", sub14:"devienne"
  };

  let scoreSubj = 0;
  data.push(["Question", "Réponse de l'étudiant", "Réponse correcte"]);

  for (let key in answersSubj) {
    let user = document.getElementById(key).value || "";
    let correct = answersSubj[key];
    if(user.toLowerCase().trim() === correct) scoreSubj++;
    data.push([key, user, correct]);
  }

  data.push(["Score", scoreSubj + " / " + Object.keys(answersSubj).length]);
  data.push([]); // Empty line

  // Total score
  const totalPoints = scoreSI + scoreSubj;
  const totalMax = Object.keys(answersSI).length + Object.keys(answersSubj).length;
  data.push(["Score total", totalPoints + " / " + totalMax]);

  // Convert to CSV string
  const csvContent = data.map(row => row.map(field => `"${field}"`).join(",")).join("\n");

  // Create blob and download
  const blob = new Blob([csvContent], { type: "text/csv;charset=utf-8;" });
  const url = URL.createObjectURL(blob);

  const a = document.createElement("a");
  a.href = url;
  a.download = "rapport_exercices.csv";
  document.body.appendChild(a);
  a.click();
  document.body.removeChild(a);
  URL.revokeObjectURL(url);
}
</script>

<input id="studentName" placeholder="Votre nom" style="margin-bottom:15px; padding:8px;">

<button type="button" onclick="sendToGoogleForm()">Envoyer les résultats à Google Form</button>

<script>
function sendToGoogleForm() {
  // Get student name
  const studentName = document.getElementById("studentName").value.trim();
  if (!studentName) {
    alert("Veuillez entrer le nom de l'étudiant !");
    return;
  }

  // Calculate scores (reuse your existing functions)
  let scoreSI = 0;
  const answersSI = { si1:"S", si2:"I", si3:"S", si4:"I", si5:"S", si6:"I", si7:"S", si8:"S", si9:"I", si10:"S" };
  for (let key in answersSI) {
    let val = document.getElementById(key).value;
    if (val === answersSI[key]) scoreSI++;
  }

  let scoreSubj = 0;
  const answersSubj = {
    sub1:"fassiez", sub2:"viennent", sub3:"ait", sub4:"saches",
    sub5:"puisse", sub6:"soit", sub7:"veuillent", sub8:"alliez",
    sub9:"prenne", sub10:"servions", sub11:"ayez",
    sub12:"soit", sub13:"fassent", sub14:"devienne"
  };
  for (let key in answersSubj) {
    let val = document.getElementById(key).value.toLowerCase().trim();
    if (val === answersSubj[key]) scoreSubj++;
  }

  // Google Form URL (replace with your Form's "action URL")
  const formUrl = "https://docs.google.com/forms/d/e/1ktk9C64cCNjrE14SHSJshLn75oIBIIi-Y4EMEXcDoAc/formResponse";

  // Map your Form fields (replace entry.XXXX with your field IDs)
  const data = new URLSearchParams();
  data.append("entry.1234567890", studentName);          // Student name field
  data.append("entry.2345678901", scoreSI);              // Subjonctif/Indicatif score
  data.append("entry.3456789012", scoreSubj);            // Subjunctive fill-in score

  // Send data via POST
  fetch(formUrl, { method: "POST", body: data })
    .then(() => alert("Résultats envoyés !"))
    .catch(err => console.error(err));
}
</script>
  
